{
    "name": "@ovencord/cross-hosting",
    "version": "1.0.8",
    "description": "Massively scalable multi-server orchestration for Discord bots. 100% Bun-native. 0% Node.js bloat. Stop emulating, start scaling.",
    "main": "src/index.ts",
    "type": "module",
    "dependencies": {
        "@ovencord/hybrid-sharding": "latest"
    },
    "scripts": {
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "format": "biome format --write .",
        "start:bridge": "bun src/test/server.ts",
        "start:cluster": "bun src/test/cluster.ts",
        "test": "bun test"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ovencord/cross-hosting.git"
    },
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "discord",
        "bun",
        "ovencord",
        "cross-hosting",
        "sharding",
        "clustering"
    ],
    "author": "LuigiColantuono",
    "license": "MIT",
    "devDependencies": {
        "@biomejs/biome": "2.4.8",
        "@types/bun": "latest",
        "redis": "5.11.0",
        "typescript": "5.9.3"
    }
}
